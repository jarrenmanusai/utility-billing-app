{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote",
    "requireCommit": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "image": "ubuntu-24.04-jdk-17-ndk-r27b"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "image": "ubuntu-24.04-jdk-17-ndk-r27b",
        "gradleCommand": ":app:assembleRelease"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk",
        "image": "ubuntu-24.04-jdk-17-ndk-r27b",
        "gradleCommand": ":app:assembleRelease",
        "ndk": "27.1.12297006"
      }
    },
    "production-aab": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle",
        "image": "ubuntu-24.04-jdk-17-ndk-r27b",
        "gradleCommand": ":app:bundleRelease",
        "ndk": "27.1.12297006"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
