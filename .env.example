# UtilityFlow Backend — Environment Variables
# Copy this file to .env and fill in your values.

# MySQL connection string
DATABASE_URL=mysql://user:password@localhost:3306/utility_billing

# Secret for signing JWTs and CAPTCHA tokens (min 32 chars recommended)
JWT_SECRET=change-this-to-a-long-random-string

# Server port
PORT=3000

# Node environment
NODE_ENV=development

# OpenAI-compatible API for OCR (meter reading extraction)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# S3-compatible storage (optional — file uploads won't persist without this)
STORAGE_API_URL=
STORAGE_API_KEY=

# Comma-separated allowed origins for CORS in production
ALLOWED_ORIGINS=https://yourdomain.com
